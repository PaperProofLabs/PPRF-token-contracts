SUI_PRIVATE_KEY=suiprivkeyxxxxx

# Optional: the scripts now prefer Published.toml for the current package ID.
# Only set PPRF_PACKAGE_ID if you want to override that behavior.
#PPRF_PACKAGE_ID=

# Optional: defaults to the shared CoinRegistry object on mainnet.
#PPRF_COIN_REGISTRY_ID=0xc

# Optional: set this only when auto-discovery from the publish transaction is not enough.
#PPRF_PUBLISH_DIGEST=
#PPRF_PENDING_CURRENCY_OBJECT_ID=

# Optional: once finalize_registration completes, store the shared Currency<PPRF> object here
# so set_pprf_logo.mjs can update icon_url directly without extra lookup.
PPRF_CURRENCY_OBJECT_ID=0x3f105caf943b3b4a7c837553ec5b4782340ce1b99b99c2b0a57aeea2b1039e59

# Optional: signer-owned metadata authority object. The logo script can discover it automatically.
#PPRF_METADATA_LOCK_ID=

# Network and Walrus settings.
SUI_NETWORK=mainnet
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
WALRUS_WASM_URL=https://unpkg.com/@mysten/walrus-wasm@latest/web/walrus_wasm_bg.wasm
WALRUS_UPLOAD_RELAY_URL=https://upload-relay.mainnet.walrus.space
WALRUS_DOWNLOAD_BASE_URL=https://aggregator.walrus-mainnet.walrus.space
WALRUS_EPOCHS=53
WALRUS_DELETABLE=false
WALRUS_UPLOAD_RELAY_TIP_MAX_MIST=3000000

# Optional: defaults to ../docs/logo.png
#PPRF_LOGO_PATH=
